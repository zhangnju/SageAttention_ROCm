  using fp8_type = __hip_fp8_e4m3_fnuz;  // FNUZ: rocwmma ROCWMMA_FP8_FNUZ path
#else
  using fp8_type = __hip_fp8_e4m3;       // OCP:  rocwmma ROCWMMA_FP8 path
