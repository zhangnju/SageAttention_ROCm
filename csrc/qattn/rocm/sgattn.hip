//   gfx950 (CDNA4, MI355X)  : OCP  (fp8_e4m3),      MFMA = fp8_fp8, wave64
//   gfx11xx/gfx12xx (RDNA)  : OCP  (fp8_e4m3),      MFMA = fp8_fp8, wave32
